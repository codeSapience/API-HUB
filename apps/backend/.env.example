# ============================================================
# Naija API Hub - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
# ============================================================

# ============================================================
# App Configuration
# ============================================================
APP_NAME=Naija API Hub
DEBUG=true
ENVIRONMENT=development          # development, staging, production
API_GATEWAY_BASE_URL=http://localhost:8000
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ============================================================
# Database (PostgreSQL)
# ============================================================
# Local development (Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/naija_api_hub

# For production, use something like:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/naija_api_hub

# ============================================================
# Redis (Cache, Rate Limiting, Queues)
# ============================================================
# Local development (Docker)
REDIS_URL=redis://localhost:6379/0

# For production with password:
# REDIS_URL=redis://:password@host:6379/0

# ============================================================
# JWT & Security (Magic Links)
# ============================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-32-byte-hex-string-in-production
JWT_ALGORITHM=HS256
MAGIC_LINK_EXPIRY_MINUTES=15
MAGIC_LINK_TOKEN_LENGTH=64

# ============================================================
# Email (Resend)
# ============================================================
# Sign up at https://resend.com
RESEND_API_KEY=re_1234567890abcdef
FROM_EMAIL=noreply@naijaapihub.com
SUPPORT_EMAIL=support@naijaapihub.com

# ============================================================
# Email (Alternative - SendGrid)
# ============================================================
# Uncomment if using SendGrid instead of Resend
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@naijaapihub.com

# ============================================================
# Payments (Stripe Connect)
# ============================================================
# Sign up at https://stripe.com
STRIPE_SECRET_KEY=sk_test_1234567890abcdef
STRIPE_PUBLISHABLE_KEY=pk_test_1234567890abcdef
STRIPE_WEBHOOK_SECRET=whsec_1234567890abcdef
STRIPE_CONNECT_CLIENT_ID=ca_1234567890abcdef

# For production, switch to live keys:
# STRIPE_SECRET_KEY=sk_live_1234567890abcdef
# STRIPE_PUBLISHABLE_KEY=pk_live_1234567890abcdef

# ============================================================
# Payments (Paystack - Local)
# ============================================================
# Sign up at https://paystack.com
PAYSTACK_SECRET_KEY=sk_test_1234567890abcdef
PAYSTACK_PUBLIC_KEY=pk_test_1234567890abcdef
PAYSTACK_WEBHOOK_SECRET=whsec_1234567890abcdef

# For production:
# PAYSTACK_SECRET_KEY=sk_live_1234567890abcdef
# PAYSTACK_PUBLIC_KEY=pk_live_1234567890abcdef

# ============================================================
# Platform Settings
# ============================================================
PLATFORM_COMMISSION_PERCENT=20.0           # Commission taken from each transaction
MINIMUM_PAYOUT_AMOUNT=5000                 # Minimum payout amount in Naira
PAYOUT_CYCLE_DAY=1                         # Day of month for provider payouts (1 = 1st)
INVOICE_GENERATION_DAY=1                   # Day of month to generate invoices

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_DEFAULT=100                     # Requests per minute per API key
RATE_LIMIT_FREE_TIER=10                    # Requests per minute for free tier
RATE_LIMIT_BURST_MULTIPLIER=2              # Burst limit = default * multiplier

# ============================================================
# Monitoring & Logging
# ============================================================
LOG_LEVEL=info                             # debug, info, warning, error
SENTRY_DSN=                                 # Optional: https://sentry.io DSN

# ============================================================
# Celery (Background Tasks)
# ============================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false             # Set to true for testing (run tasks synchronously)

# ============================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================
# For development:
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# For production, add your frontend domain:
# CORS_ORIGINS=["https://app.naijaapihub.com", "https://naijaapihub.com"]

# ============================================================
# Admin User (Initial Setup)
# ============================================================
# Create admin user on first run if not exists
ADMIN_EMAIL=admin@naijaapihub.com
ADMIN_NAME=Admin

# ============================================================
# Feature Flags
# ============================================================
ENABLE_PROVIDER_SIGNUP=true
ENABLE_DIRECT_PAYOUTS=true
ENABLE_MARKETPLACE=true
ENABLE_WEBSOCKETS=false                    # Future feature

# ============================================================
# External API Timeouts (seconds)
# ============================================================
PROXY_TIMEOUT=30                           # Timeout for proxying requests to provider APIs
PROXY_CONNECT_TIMEOUT=10                   # Connection timeout for proxy
PROXY_MAX_RETRIES=2                        # Number of retries for failed proxy requests

# ============================================================
# File Upload (for API logos, docs, etc.)
# ============================================================
MAX_UPLOAD_SIZE_MB=5
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,gif,svg,pdf

# ============================================================
# Session & Cookie Settings
# ============================================================
SESSION_EXPIRY_DAYS=30
COOKIE_SECURE=false                         # Set to true in production (HTTPS only)
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# ============================================================
# Development Only (Never use in production)
# ============================================================
# Bypass email sending (print magic link to console instead)
DEV_BYPASS_EMAIL=false

# Mock payment providers (for testing without real keys)
DEV_MOCK_PAYMENTS=false